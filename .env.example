# ─────────────────────────────────────────────────────────────────────────────
# ByggKalkyl – exempel på miljövariabler. Kopiera till .env och fyll i.
# ALDRIG checka in den riktiga .env-filen (den är gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# --- Databas (PostgreSQL) -----------------------------------------------------
# Neon (rekommenderat i denna miljö – ingen Docker behövs).
# Skapa ett gratis projekt på https://neon.tech och kopiera connection strings.
#
# DATABASE_URL = "pooled" anslutning (för app/serverless). Innehåller "-pooler".
# DIRECT_URL   = direkt anslutning (för Prisma migrate/seed, utan pooler).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
#
# Alternativ – lokal Postgres via docker-compose (kräver Docker):
# DATABASE_URL="postgresql://byggkalkyl:byggkalkyl@localhost:5432/byggkalkyl?schema=public"
# DIRECT_URL="postgresql://byggkalkyl:byggkalkyl@localhost:5432/byggkalkyl?schema=public"

# --- AI-mängdning (GRATIS) ----------------------------------------------------
# AI används för (a) tolkning av PDF-ritningar (vision) och (b) stökiga rumslistor.
# Helt valfritt: utan nyckel funkar IFC (auto), Excel och manuell inmatning ändå.
# Bakom utbytbart LLMProvider-interface. Hämtas från env, ALDRIG i koden.
#
# AI_PROVIDER: gemini (gratis, default) | none (AI av)
AI_PROVIDER="gemini"
# Gratis Gemini-nyckel via Google AI Studio – INGET kreditkort:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- IFC/PDF-mikrotjänst (Python FastAPI) ------------------------------------
# Lokalt: http://localhost:8000. I moln: Render-/Fly-URL.
IFC_SERVICE_URL="http://localhost:8000"

# --- Fillagring (StorageService) ---------------------------------------------
# local  = spara på disk i ./apps/web/storage (dev)
# blobs  = Netlify Blobs (prod på Netlify)
# s3     = S3/R2 (prod, kräver nycklar nedan)
STORAGE_DRIVER="local"
STORAGE_DIR="./storage"
# S3/R2 (endast om STORAGE_DRIVER=s3):
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# --- Kalkylinställningar (default) -------------------------------------------
ARBETSDAG_TIMMAR="8"
